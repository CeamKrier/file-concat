{
    "name": "file-concat",
    "version": "0.1.0",
    "description": "Privacy-first CLI for concatenating files into LLM context, with optional PDF/DOCX/XLSX/PPTX/ODT/ODS/ODP extraction",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "file-concat": "./dist/index.js"
    },
    "engines": {
        "node": ">=18"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "start": "tsx src/index.ts",
        "dev": "tsx src/index.ts",
        "build": "tsup",
        "prepublishOnly": "pnpm run build",
        "check": "tsc --noEmit",
        "test": "pnpm run build && vitest run"
    },
    "keywords": [
        "cli",
        "llm",
        "concatenate",
        "files",
        "context",
        "ai",
        "chatgpt",
        "claude",
        "gemini",
        "file-concat",
        "repomix"
    ],
    "author": "Emre Çakır <hello@ceamkrier.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/CeamKrier/file-concat.git",
        "directory": "packages/cli"
    },
    "homepage": "https://fileconcat.com",
    "dependencies": {
        "commander": "^12.0.0",
        "glob": "^11.0.0",
        "officeparser": "^7.2.1"
    },
    "devDependencies": {
        "@fileconcat/core": "workspace:*",
        "@types/node": "^22.0.0",
        "execa": "^9.6.1",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.8"
    },
    "publishConfig": {
        "access": "public"
    }
}
